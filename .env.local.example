# Supabase — create a free project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── LLM Configuration ────────────────────────────
# Anthropic Claude API — primary LLM backbone
# Haiku handles 5/6 features ($1/$5 MTok); Sonnet used only for Socratic interviews ($3/$15 MTok)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Embedding Configuration ──────────────────────
# Default: Google text-embedding-005 ($0.00625/MTok, 768 dims)
# 3.2x cheaper than OpenAI 3-small with comparable quality
GOOGLE_API_KEY=your-google-api-key-here

# To use OpenAI embeddings instead, uncomment these and set your key:
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ── Model Overrides (defaults shown) ─────────────
# CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
# CLAUDE_MODEL_SONNET=claude-sonnet-4-6-20260416
# EMBEDDING_MODEL=text-embedding-005
# EMBEDDING_DIMENSIONS=768
