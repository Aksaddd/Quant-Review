# Supabase — create a free project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── LLM Provider Selection ───────────────────────
# Default: "gemini" (10x cheaper). Set to "claude" to use Anthropic instead.
# LLM_PROVIDER=gemini

# ── Google API Key (powers Gemini LLM + embeddings) ───
# Required for: Gemini Flash Lite ($0.10/$0.40 MTok), Gemini Flash ($0.30/$2.50),
#               and text-embedding-005 ($0.00625/MTok)
# Free tier available: 1,000 req/day on Flash Lite, 250/day on Flash
GOOGLE_API_KEY=your-google-api-key-here

# ── Anthropic Claude API (fallback LLM) ─────────
# Used as fallback when Gemini fails, or when LLM_PROVIDER=claude
# Haiku: $1/$5 MTok, Sonnet: $3/$15 MTok
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Embedding Configuration ──────────────────────
# Default: Google text-embedding-005 ($0.00625/MTok, 768 dims)
# To use OpenAI embeddings instead, uncomment below:
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ── Model Overrides (defaults shown) ─────────────
# GEMINI_MODEL_LITE=gemini-2.5-flash-lite
# GEMINI_MODEL_FLASH=gemini-2.5-flash
# CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
# CLAUDE_MODEL_SONNET=claude-sonnet-4-6-20260416
# EMBEDDING_MODEL=text-embedding-005
# EMBEDDING_DIMENSIONS=768
